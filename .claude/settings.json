{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(git restore:*)",
      "Bash(git stash:*)",
      "Bash(git tag:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git revert:*)",
      "Bash(git apply:*)",
      "Bash(git rm:*)",
      "Bash(git mv:*)",
      "Bash(git clean:*)"
    ]
  }
}
