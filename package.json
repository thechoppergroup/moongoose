{
  "name": "@thechoppergroup/moongoose",
  "version": "0.5.112",
  "description": "SVG Icon Library",
  "main": "dist/moongoose.js",
  "module": "dist/moongoose.mjs",
  "exports": {
    ".": {
      "import": "./dist/moongoose.mjs",
      "require": "./dist/moongoose.js",
      "default": "./dist/moongoose.js"
    },
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/"
  },
  "scripts": {
    "clean": "node scripts/clean.js",
    "build": "npm run clean && node scripts/svg-to-module.js && vite build --config vite.lib.config.mjs",
    "serve": "node scripts/svg-to-module.js && vite --config vite.docs.config.mjs",
    "watch": "npm run serve",
    "release": "npm run build && npm version patch && npm publish",
    "build-docs": "node scripts/svg-to-module.js && vite build --config vite.docs.config.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:thechoppergroup/moongoose.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/thechoppergroup/moongoose/issues"
  },
  "homepage": "https://github.com/thechoppergroup/moongoose#readme",
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/compiler-sfc": "^3.5.0",
    "copy-to-clipboard": "^3.3.3",
    "cross-env": "^7.0.3",
    "lodash": "^4.17.10",
    "sass": "^1.69.0",
    "svg-to-dataurl": "^1.0.0",
    "svgo": "^3.0.2",
    "thin.css": "^1.0.2",
    "vite": "^8.0.0",
    "vue": "^3.5.0"
  }
}
